{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/router.py status --json",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "command": "cat ${CLAUDE_PLUGIN_ROOT}/skills/agent-hub/SKILL.md"
          }
        ]
      }
    ]
  }
}
